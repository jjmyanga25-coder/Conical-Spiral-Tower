@page
@model IndexModel
@{
    ViewData["Title"] = "Conical Spiral Tower Calculator";
}

<h2>Conical Spiral Tower Volume</h2>

<form method="post">
    <label>Base Radius (r0):</label><br />
    <input type="number" step="any" name="Radius" required /><br /><br />

    <label>Height (h):</label><br />
    <input type="number" step="any" name="Height" required /><br /><br />

    <label>Spiral Factor (k):</label><br />
    <input type="number" step="any" name="K" required /><br /><br />

    <label>Frequency (ω):</label><br />
    <input type="number" step="any" name="Omega" required /><br /><br />

    <button type="submit">Calculate</button>
</form>

@if (Model.Volume > 0)
{
    <h3>Volume: @Model.Volume.ToString("F2")</h3>
}